generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Admin ────────────────────────────────────────────────────────────────────
model Admin {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("admins")
}

// ─── Branch (Sucursal) ────────────────────────────────────────────────────────
model Branch {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String
  address     String
  phone       String
  email       String?
  mapEmbedUrl String?
  hours       Json     // { "1": "09:00–20:00", ..., "0": null }
  imageUrl    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  professionals Professional[]
  appointments  Appointment[]

  @@map("branches")
}

// ─── Service ──────────────────────────────────────────────────────────────────
model Service {
  id          Int     @id @default(autoincrement())
  slug        String  @unique
  name        String
  category    String
  description String?
  durationMin Int
  bufferMin   Int     @default(0)
  price       Decimal @db.Decimal(10, 2)
  popular     Boolean @default(false)
  active      Boolean @default(true)
  imageUrl    String?
  createdAt   DateTime @default(now())

  professionals ProfessionalService[]
  appointments  AppointmentService[]

  @@map("services")
}

// ─── Professional (Peluquero) ─────────────────────────────────────────────────
model Professional {
  id           Int      @id @default(autoincrement())
  name         String
  role         String
  bio          String?
  photoUrl     String?
  branchId     Int
  branch       Branch   @relation(fields: [branchId], references: [id])
  active       Boolean  @default(true)
  // JSON: { "0": null, "1": [{from:"09:00",to:"20:00"}], ... }
  // 0=dom, 1=lun, ..., 6=sab. null = día libre
  availability Json
  instagram    String?
  rating       Decimal  @default(5.0) @db.Decimal(3, 1)
  reviewCount  Int      @default(0)
  createdAt    DateTime @default(now())

  services     ProfessionalService[]
  appointments Appointment[]

  @@map("professionals")
}

model ProfessionalService {
  professionalId Int
  serviceId      Int
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([professionalId, serviceId])
  @@map("professional_services")
}

// ─── Customer ─────────────────────────────────────────────────────────────────
model Customer {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  phone        String?
  notes        String?
  createdAt    DateTime      @default(now())
  appointments Appointment[]

  @@map("customers")
}

// ─── Appointment (Turno) ──────────────────────────────────────────────────────
enum AppointmentStatus {
  PENDIENTE
  CONFIRMADO
  CANCELADO
  COMPLETADO
  NO_SHOW
}

model Appointment {
  id               String            @id @default(cuid())
  branchId         Int
  branch           Branch            @relation(fields: [branchId], references: [id])
  professionalId   Int?
  professional     Professional?     @relation(fields: [professionalId], references: [id])
  customerId       Int
  customer         Customer          @relation(fields: [customerId], references: [id])
  date             DateTime          @db.Date
  startTime        String            // "14:00"
  endTime          String            // "15:30"
  totalDurationMin Int
  totalPrice       Decimal           @db.Decimal(10, 2)
  status           AppointmentStatus @default(PENDIENTE)
  notes            String?
  cancelToken      String?           @unique
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  services AppointmentService[]

  // Evita double booking: mismo peluquero + misma fecha + mismo horario de inicio
  @@unique([professionalId, date, startTime])
  @@index([branchId, date])
  @@index([customerId])
  @@index([status])
  @@map("appointments")
}

model AppointmentService {
  appointmentId String
  serviceId     Int
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service       Service     @relation(fields: [serviceId], references: [id])

  @@id([appointmentId, serviceId])
  @@map("appointment_services")
}
