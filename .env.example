# ─── Base de datos ────────────────────────────────────────────────────────────
# Local (Docker): postgresql://studiohair:studiohair_dev@localhost:5432/studiohair
# Neon (Vercel Integration): usar el valor de POSTGRES_PRISMA_URL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# URL directa sin pooling → usada por Prisma para migraciones.
# Local: igual a DATABASE_URL
# Neon (Vercel Integration): usar el valor de POSTGRES_URL_NON_POOLING
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Genera uno con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="cambia-esto-por-una-cadena-larga-y-completamente-aleatoria"
JWT_EXPIRES_IN="7d"

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
# Para Gmail: activá "App Passwords" en tu cuenta de Google
# https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="tu-email@gmail.com"
SMTP_PASS="tu-app-password-de-16-caracteres"
EMAIL_FROM="Studio Hair <no-reply@studiohair.com.ar>"

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
BASE_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Admin inicial (solo para seed) ──────────────────────────────────────────
ADMIN_EMAIL="admin@studiohair.com.ar"
ADMIN_PASSWORD="cambiar-en-produccion-123"
